APP_NAME="FuelOps"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/umachi
APP_TIMEZONE=Africa/Lagos
GMAIL_URL=https://mail.google.com/
WEBMAIL_URL=https://mail.yourcompany.com/


DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=umachi
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_SMTP_AUTH=true
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="UMACHI Oil & Gas Ltd"
MAIL_COMPANY_NAME="UMACHI Oil & Gas Ltd"
MAIL_COMPANY_LOGO_URL=
MAIL_COMPANY_ADDRESS=
MAIL_COMPANY_PHONE=
MAIL_COMPANY_EMAIL=
MAIL_LOGIN_URL=http://localhost/umachi/index.php?route=login
MAIL_TIMEOUT=15
SESSION_TIMEOUT_MINUTES=30
AUTH_FAILED_LOGIN_LIMIT=5
AUTH_FAILED_LOGIN_WINDOW_MINUTES=15
AUTH_LOCKOUT_MINUTES=30
AUTH_DEFAULT_REDIRECT=dashboard
AUTH_ADMIN_REDIRECT=admin/dashboard

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=password1
DEFAULT_ADMIN_ROLE=Admin
DEFAULT_ADMIN_FULL_NAME="System Administrator"
DEFAULT_ADMIN_EMAIL=admin@umachi.com
DEFAULT_ADMIN_STATUS=active
