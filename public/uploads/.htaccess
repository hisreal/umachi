Options -Indexes -ExecCGI

RemoveHandler .php .php3 .php4 .php5 .phtml .phar .cgi .pl .py .sh
RemoveType .php .php3 .php4 .php5 .phtml .phar .cgi .pl .py .sh

<FilesMatch "\.(?:php[0-9]?|phtml|phar|cgi|pl|py|sh|exe|dll|com|bat|cmd|svg|svgz)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
